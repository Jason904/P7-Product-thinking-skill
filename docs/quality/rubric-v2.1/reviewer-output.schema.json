{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/hermes/reviewer-output.schema.json",
  "title": "Rubric v2.1 Reviewer Output",
  "type": "object",
  "additionalProperties": false,
  "x_enum_source": "rubric-enums.yaml",
  "x_formula_checks": [
    "capped_score <= raw_score",
    "adjusted_score <= capped_score",
    "final_score == adjusted_score",
    "final_score <= max_score",
    "final_score <= active item cap",
    "account_raw_score == sum(item.final_score for account items)",
    "account_final_score <= account_raw_score",
    "case_raw_total == sum(account.account_final_score)",
    "case_final_total <= case_raw_total",
    "if global cap applies then case_final_total <= global cap",
    "daily PASS requires every deep case PASS and G6/G7/G8 PASS",
    "reviewer_output_valid false blocks publish decision"
  ],
  "required": [
    "reviewer_output_valid",
    "reviewer_id",
    "reviewed_at",
    "rubric_version",
    "case_score_policy",
    "daily_score_policy",
    "daily_decision_rule",
    "daily_decision",
    "publish_allowed",
    "case_reviews"
  ],
  "properties": {
    "reviewer_output_valid": {
      "type": "boolean"
    },
    "reviewer_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_at": {
      "type": "string",
      "minLength": 1
    },
    "rubric_version": {
      "const": "2.1"
    },
    "case_score_policy": {
      "const": "each_deep_case_scored_independently_100"
    },
    "daily_score_policy": {
      "const": "no_cross_case_compensation"
    },
    "daily_decision_rule": {
      "const": "all_cases_must_pass"
    },
    "daily_decision": {
      "$ref": "#/$defs/decision_state"
    },
    "publish_allowed": {
      "type": "boolean"
    },
    "gate_statuses": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "G6": {
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "G7": {
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "G8": {
          "enum": [
            "PASS",
            "FAIL"
          ]
        }
      }
    },
    "case_reviews": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/case_review"
      }
    },
    "review_notes": {
      "type": "string"
    }
  },
  "$defs": {
    "decision_state": {
      "type": "string",
      "enum": [
        "PASS",
        "PASS_WITH_MINOR_REPAIR",
        "REVIEW",
        "REWRITE_MODULE",
        "REWRITE_CASE",
        "REPLACE_CASE",
        "FAIL_DAILY",
        "PUBLISH_BLOCK",
        "USER_REVIEW_REQUIRED"
      ]
    },
    "evidence_sufficiency": {
      "type": "string",
      "enum": [
        "SUFFICIENT",
        "PARTIAL",
        "INSUFFICIENT",
        "MISSING"
      ]
    },
    "cap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cap_type",
        "reason",
        "max_allowed_score"
      ],
      "properties": {
        "cap_type": {
          "type": "string",
          "enum": [
            "item_cap",
            "account_cap",
            "global_cap"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "max_allowed_score": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "deduction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "points"
      ],
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "points": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "required_evidence_point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "point",
        "support_level"
      ],
      "properties": {
        "point": {
          "type": "string",
          "minLength": 1
        },
        "support_level": {
          "$ref": "#/$defs/evidence_sufficiency"
        },
        "best_supporting_evidence_id": {
          "type": "string"
        },
        "missing_or_partial_reason": {
          "type": "string"
        }
      }
    },
    "positive_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quote",
        "location",
        "supports_what",
        "evidence_sufficiency"
      ],
      "properties": {
        "evidence_id": {
          "type": "string"
        },
        "quote": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "supports_what": {
          "type": "string",
          "minLength": 1
        },
        "evidence_sufficiency": {
          "$ref": "#/$defs/evidence_sufficiency"
        },
        "why_insufficient": {
          "type": "string"
        }
      }
    },
    "item_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "level",
        "primary_account",
        "max_score",
        "raw_score",
        "caps_applied",
        "capped_score",
        "deductions_applied",
        "adjusted_score",
        "final_score",
        "anchor_matched",
        "required_evidence_points",
        "item_evidence_sufficiency",
        "positive_evidence",
        "missing_evidence",
        "deduction_reason",
        "why_not_higher",
        "repair_action",
        "decision"
      ],
      "properties": {
        "item_id": {
          "type": "string"
        },
        "level": {
          "type": "string",
          "enum": [
            "S",
            "A",
            "B"
          ]
        },
        "primary_account": {
          "type": "string",
          "enum": [
            "thinking_depth",
            "content_quality",
            "expression_quality"
          ]
        },
        "max_score": {
          "type": "integer",
          "minimum": 1
        },
        "raw_score": {
          "type": "integer",
          "minimum": 0
        },
        "caps_applied": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cap"
          }
        },
        "capped_score": {
          "type": "integer",
          "minimum": 0
        },
        "deductions_applied": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/deduction"
          }
        },
        "adjusted_score": {
          "type": "integer",
          "minimum": 0
        },
        "final_score": {
          "type": "integer",
          "minimum": 0
        },
        "anchor_matched": {
          "type": "string",
          "minLength": 1
        },
        "required_evidence_points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/required_evidence_point"
          }
        },
        "item_evidence_sufficiency": {
          "$ref": "#/$defs/evidence_sufficiency"
        },
        "positive_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/positive_evidence"
          }
        },
        "missing_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deduction_reason": {
          "type": "string"
        },
        "why_not_higher": {
          "type": "string"
        },
        "repair_action": {
          "type": "string"
        },
        "decision": {
          "$ref": "#/$defs/decision_state"
        }
      }
    },
    "account_score": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "account_id",
        "account_raw_score",
        "account_cap_applied",
        "account_final_score",
        "min_pass_score"
      ],
      "properties": {
        "account_id": {
          "type": "string",
          "enum": [
            "thinking_depth",
            "content_quality",
            "expression_quality"
          ]
        },
        "account_raw_score": {
          "type": "integer",
          "minimum": 0
        },
        "account_cap_applied": {
          "oneOf": [
            {
              "$ref": "#/$defs/cap"
            },
            {
              "type": "null"
            }
          ]
        },
        "account_final_score": {
          "type": "integer",
          "minimum": 0
        },
        "min_pass_score": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "case_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "case_title",
        "claim_evidence_map",
        "item_reviews",
        "account_scores",
        "case_raw_total",
        "case_global_cap_applied",
        "case_final_total",
        "case_decision",
        "publish_allowed"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "enum": [
            "case_a",
            "case_b",
            "case_c"
          ]
        },
        "case_title": {
          "type": "string",
          "minLength": 1
        },
        "claim_evidence_map": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "object"
          }
        },
        "item_reviews": {
          "type": "array",
          "minItems": 21,
          "items": {
            "$ref": "#/$defs/item_review"
          }
        },
        "account_scores": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "$ref": "#/$defs/account_score"
          }
        },
        "case_raw_total": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "case_global_cap_applied": {
          "oneOf": [
            {
              "$ref": "#/$defs/cap"
            },
            {
              "type": "null"
            }
          ]
        },
        "case_final_total": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "case_decision": {
          "$ref": "#/$defs/decision_state"
        },
        "publish_allowed": {
          "type": "boolean"
        }
      }
    }
  }
}
