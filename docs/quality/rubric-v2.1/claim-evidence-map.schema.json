{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/hermes/claim-evidence-map.schema.json",
  "title": "Rubric v2.1 Claim Evidence Map",
  "type": "object",
  "additionalProperties": false,
  "x_enum_source": "rubric-enums.yaml",
  "x_governance_rules": [
    "Each deep case must include 1-3 core claims.",
    "Every core claim must bind to traceable supporting_facts.",
    "C/D facts cannot support core_claim",
    "Fact Confidence Table existence does not prove claim support.",
    "If source title, url, or fact_confidence is missing, support_level cannot be SUFFICIENT."
  ],
  "required": [
    "case_id",
    "claims"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "enum": [
        "case_a",
        "case_b",
        "case_c"
      ]
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/claim"
      }
    }
  },
  "$defs": {
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "claim_text",
        "claim_type",
        "supporting_facts",
        "support_level",
        "unsupported_parts",
        "decision_impact"
      ],
      "properties": {
        "claim_id": {
          "type": "string",
          "minLength": 1
        },
        "claim_text": {
          "type": "string",
          "minLength": 1
        },
        "claim_type": {
          "type": "string",
          "enum": [
            "core_judgment",
            "final_tradeoff",
            "trend_projection",
            "value_flow"
          ]
        },
        "supporting_facts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/supporting_fact"
          }
        },
        "support_level": {
          "type": "string",
          "enum": [
            "SUFFICIENT",
            "PARTIAL",
            "INSUFFICIENT",
            "MISSING"
          ]
        },
        "unsupported_parts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decision_impact": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "supporting_fact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fact",
        "source",
        "supports_claim_how"
      ],
      "properties": {
        "fact": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "title",
            "url",
            "source_type",
            "published_at",
            "accessed_at",
            "fact_confidence"
          ],
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "minLength": 1
            },
            "source_type": {
              "type": "string",
              "enum": [
                "official_doc",
                "github_repo",
                "paper",
                "media",
                "ai_hot",
                "community"
              ]
            },
            "published_at": {
              "type": "string"
            },
            "accessed_at": {
              "type": "string",
              "minLength": 1
            },
            "fact_confidence": {
              "type": "string",
              "enum": [
                "A",
                "B",
                "C",
                "D"
              ]
            }
          }
        },
        "supports_claim_how": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
